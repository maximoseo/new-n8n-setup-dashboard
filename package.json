{
  "name": "new-site-onboarding-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1 --port 5177\" \"tsx watch server/index.ts\"",
    "dev:client": "vite --host 127.0.0.1 --port 5177",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4177",
    "start": "node dist-server/server/index.js",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json",
    "test": "node --import tsx --test server/cloner/__tests__/*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cheerio": "^1.0.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
